generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Car {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  brand      String
  model      String
  mileage    Int
  year       Int
  created_at DateTime? @default(now())
  updated_at DateTime? @default(now())

  @@map("cars")
}
